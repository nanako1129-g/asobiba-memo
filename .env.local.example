# --- ローカル開発 ---
# このファイルをコピーして `.env.local` を作り、値を入れてください。
#
# 【最短で動かす】変数なしでも `npm run dev` で一覧・詳細はサンプル4件が見られます（デモ表示）。
# 投稿の保存・画像アップロードを試すときだけ、下の2つを必ず設定してください。
#
# --- Vercel ---
# Dashboard → 該当プロジェクト → Settings → Environment Variables に
# 同じ変数名で設定してください（Production と Preview の両方に入れるのを推奨）。
# 変更後は「Redeploy」で再ビルドすると確実です。

# Supabase → Project Settings → API Keys
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
# 次のどちらか1つ（ダッシュボードに合わせる）
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# 従来の anon JWT を使う場合はこちら
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# OpenAI（AIあそび方提案・下書き）— https://platform.openai.com/api-keys
# 未設定のときは「デモ表示」のサンプル文が返ります（本番の AI 生成には設定が必要）
OPENAI_API_KEY=

# Supabase service_role（投稿の編集のみ Server Action で使用。絶対にクライアントに出さない）
# Project Settings → API → service_role（secret）
SUPABASE_SERVICE_ROLE_KEY=

# 自分だけが /admin から一覧・編集・削除するためのパスワード（長めの文字列推奨）
ADMIN_PASSWORD=
